{
  "name": "lottery-generator-python-engine",
  "main": "src/entry.py",
  "compatibility_date": "2026-04-12",
  "compatibility_flags": ["python_workers"],
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}